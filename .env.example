# Copy to .env and fill in your keys:
#   cp .env.example .env
#
# uv run loads .env from the project root automatically.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Langfuse observability (optional — omit to disable tracing)
# Self-hosted: set LANGFUSE_HOST to your instance URL
# Cloud: leave LANGFUSE_HOST unset (defaults to cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3000

# Backtest data backend: yfinance | alpaca | parquet | csv
KYROS_DATA_BACKEND=csv
KYROS_CSV_PATH=workspace/data/nq_1min_data.csv

# Alpaca Markets data backend (optional — only used when KYROS_DATA_BACKEND=alpaca).
# Read-only market-data bars endpoint; never used for order placement.
# Leave empty to disable; never commit real keys to .env.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
